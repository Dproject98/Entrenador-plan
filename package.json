{
  "name": "entrenador-plan",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "api",
    "mobile"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=api",
    "dev:mobile": "npm run dev --workspace=mobile",
    "build:api": "npm run build --workspace=api",
